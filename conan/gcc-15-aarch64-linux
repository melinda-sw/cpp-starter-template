include(base/gcc-15-linux)

[settings]
arch=armv8

[buildenv]
CC=aarch64-linux-gnu-gcc-15
CXX=aarch64-linux-gnu-g++-15
LD=aarch64-linux-gnu-ld
CPP=aarch64-linux-gnu-cpp-15
AR=aarch64-linux-gnu-gcc-ar-15
NM=aarch64-linux-gnu-gcc-nm-15
RANLIB=aarch64-linux-gnu-gcc-ranlib-15

[conf]
tools.build:cflags+=["-mcpu=cortex-a76"]
tools.build:cxxflags+=["-mcpu=cortex-a76"]
